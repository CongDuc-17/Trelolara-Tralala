// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator zod {
  provider                         = "zod-prisma-types"
  output                           = "../src/models" // default is ./generated/zod
  useMultipleFiles                 = true // default is false
  writeBarrelFiles                 = true // default is true
  createInputTypes                 = true // default is false
  createModelTypes                 = true // default is false
  addInputTypeValidation           = true // default is false
  addIncludeType                   = true // default is false
  addSelectType                    = true // default is false
  validateWhereUniqueInput         = true // default is false
  createOptionalDefaultValuesTypes = true // default is false
  createRelationValuesTypes        = true // default is false
  createPartialTypes               = true // default is false
  useDefaultValidators             = true // default is false
  coerceDate                       = true // default is false
  writeNullishInModelTypes         = true // default is false
  prismaClientPath                 = "./path/to/prisma/client" // default is client output path 
}

enum UserStatusEnum {
  ACTIVE @map("active")
  LOCKED @map("locked")
}

enum RoleStatusEnum {
  ACTIVE   @map("active")
  INACTIVE @map("inactive")
}

enum PermissionStatusEnum {
  ACTIVE   @map("active")
  INACTIVE @map("inactive")
}

enum ProjectStatusEnum {
  ACTIVE   @map("active")
  ARCHIVED @map("archived")
  DELETED  @map("deleted")
}

enum BoardStatusEnum {
  ACTIVE   @map("active")
  ARCHIVED @map("archived")
  DELETED  @map("deleted")
}

enum ListStatusEnum {
  ACTIVE   @map("active")
  ARCHIVED @map("archived")

 
}

enum CardStatusEnum {
  ACTIVE   @map("active")
  ARCHIVED @map("archived")
  

}

enum InvitationStatusEnum {
  PENDING   @map("pending")
  ACCEPTED  @map("accepted")
  EXPIRED   @map("expired")
  CANCELLED @map("cancelled")
}

enum InvitationTypeEnum {
  EMAIL @map("email")
  LINK  @map("link")
}

enum NotificationTypeEnum {
  BOARD_INVITED
  PROJECT_INVITED
  CARD_ASSIGNED
  CARD_COMMENTED
  CARD_DUE_SOON
}

enum NotificationEntityTypeEnum {
  PROJECT
  BOARD
  CARD
  INVITATION
}

model users {
  id        String         @id @default(uuid())
  email     String         @unique
  name      String
  bio       String?
  address   String?
  avatar    String?
  verify    Boolean        @default(false)
  // @DtoCreateHidden
  // @DtoUpdateHidden
  status    UserStatusEnum @default(ACTIVE)
  createdAt DateTime       @default(now())
  // @DtoCreateHidden
  // @DtoUpdateHidden
  updatedAt DateTime       @updatedAt
  // @DtoCreateHidden
  // @DtoUpdateHidden
  deletedAt DateTime?

  accounts       accounts?
  socialAccounts socialAccounts?
  tokens         tokens[]
  otps           otps?
  usersRoles     usersRoles[]
  projectMembers projectMembers[]

  boardMembers    boardMembers[]
  cardMembers     cardMembers[]
  cardComments    cardComments[]
  cardAttachments cardAttachments[]
  cardActivity    cardActivity[]
  invitations     invitations[]
  notifications   Notifications[]

  @@map("Users")
}

model accounts {
  id       String @id @default(uuid())
  userId   String @unique @map("user_id")
  user     users  @relation(fields: [userId], references: [id])
  password String
  salt     String

  @@map("Accounts")
}

model socialAccounts {
  id                 String @id @default(uuid())
  userId             String @unique @map("user_id")
  user               users  @relation(fields: [userId], references: [id])
  googleId           String @map("google_id") @unique
  googleAccessToken  String @map("google_access_token")
  googleRefreshToken String @map("google_refresh_token")

  @@map("Social_Accounts")
}

model tokens {
  id           String @id @default(uuid())
  userId       String @map("user_id")
  user         users  @relation(fields: [userId], references: [id])
  refreshToken String @unique @map("refresh_token")
  createdAt    DateTime @default(now()) @map("created_at")
  expiresAt    DateTime @map("expires_at")

  @@map("Tokens")
}

model otps {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  user      users    @relation(fields: [userId], references: [id])
  otp       String   @db.Char(6)
  expiresAt DateTime @map("expires_at")

  @@map("Otps")
}

model emailVerifications {
  id        String   @id @default(uuid())
  email     String
  code      String   @db.Char(6)
  token     String   @unique
  attempts  Int      @default(0)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  
  @@index([email])
  @@map("Email_Verifications")
}

model usersRoles {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   users  @relation(fields: [userId], references: [id])
  roleId String @map("role_id")
  role   roles  @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@map("Users_Roles")
}

model roles {
  id          String         @id @default(uuid())
  name        String         @unique @db.VarChar(50)
  description String?
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  deletedAt   DateTime?      @map("deleted_at")
  status      RoleStatusEnum @default(ACTIVE)

  usersRoles       usersRoles[]
  rolesPermissions rolesPermissions[]
  projectMembers   projectMembers[]
  boardMembers     boardMembers[]

  @@map("Roles")
}

model rolesPermissions {
  id           String      @id @default(uuid())
  roleId       String      @map("role_id")
  role         roles       @relation(fields: [roleId], references: [id])
  permissionId String      @map("permission_id")
  permission   permissions @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("Roles_Permissions")
}

model permissions {
  id          String    @id @default(uuid())
  name        String    @unique @db.VarChar(50)
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  rolesPermissions rolesPermissions[]

  @@map("Permissions")
}

model projects {
  id          String           @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")
  members     projectMembers[]

  status     ProjectStatusEnum @default(ACTIVE)
  boards     boards[]
  invitation invitations[]     @relation("ProjectInvitation")

  @@map("Projects")
}

model projectMembers {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  project   projects @relation(fields: [projectId], references: [id])
  userId    String   @map("user_id")
  user      users    @relation(fields: [userId], references: [id])
  roleId    String   @map("role_id")
  role      roles    @relation(fields: [roleId], references: [id])
  accepted  Boolean  @default(false)
  invitedAt DateTime @default(now()) @map("invited_at")

  @@unique([projectId, userId])
  @@map("Project_Members")
}

model boards {
  id          String          @id @default(uuid())
  name        String
  description String?
  projectId   String          @map("project_id")
  project     projects        @relation(fields: [projectId], references: [id])
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  deletedAt   DateTime?       @map("deleted_at")
  status      BoardStatusEnum @default(ACTIVE)
  background   String?         

  boardMembers boardMembers[]
  invitation   invitations[]  @relation("BoardInvitation")
  lists        lists[]
  labels       labels[]

  @@map("Boards")
}

model boardMembers {
  id     String @id @default(uuid())
  roleId String @map("role_id")
  role   roles  @relation(fields: [roleId], references: [id])

  userId String @map("user_id")
  user   users  @relation(fields: [userId], references: [id])

  boardId String @map("board_id")
  board   boards @relation(fields: [boardId], references: [id])

  accepted  Boolean  @default(false)
  invitedAt DateTime @default(now()) @map("invited_at")

  @@unique([userId, boardId])
  @@map("Board_Members")
}

model lists {
  id        String    @id @default(uuid())
  name      String
  boardId   String    @map("board_id")
  board     boards    @relation(fields: [boardId], references: [id])
  position  Float
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  status    ListStatusEnum @default(ACTIVE)
  cards     cards[]

  @@map("Lists")
}

model cards {
  id          String  @id @default(uuid())
  title       String
  description String?
  listId      String  @map("list_id")
  list        lists   @relation(fields: [listId], references: [id])
  position    Float
  status      CardStatusEnum @default(ACTIVE)
  isComplete  Boolean @default(false) @map("is_complete")
  background  String?
  dueDate     DateTime?         @map("due_date")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  deletedAt   DateTime?         @map("deleted_at")
  cardMembers cardMembers[]
  cardLabels  cardLabels[]
  checklists  checklists[]
  comments    cardComments[]
  attachments cardAttachments[]
  activity    cardActivity[]

  @@map("Cards")
}

model cardMembers {
  id     String @id @default(uuid())
  cardId String @map("card_id")
  card   cards  @relation(fields: [cardId], references: [id])
  userId String @map("user_id")
  user   users  @relation(fields: [userId], references: [id])

  @@unique([cardId, userId])
  @@map("Card_Members")
}

model labels {
  id         String       @id @default(uuid())
  name       String
  color      String
  boardId    String       @map("board_id")
  board      boards       @relation(fields: [boardId], references: [id])
  cardLabels cardLabels[]
  createdAt  DateTime     @default(now()) @map("created_at")

  @@unique([boardId, name])
  @@map("Labels")
}

model cardLabels {
  id      String @id @default(uuid())
  cardId  String @map("card_id")
  card    cards  @relation(fields: [cardId], references: [id])
  labelId String @map("label_id")
  label   labels @relation(fields: [labelId], references: [id])

  @@unique([cardId, labelId])
  @@map("Card_Labels")
}

model checklists {
  id             String           @id @default(uuid())
  cardId         String           @map("card_id")
  card           cards            @relation(fields: [cardId], references: [id])
  title          String
  checklistItems checklistItems[]
  createdAt      DateTime         @default(now()) @map("created_at")

  @@map("Checklists")
}

model checklistItems {
  id          String     @id @default(uuid())
  checklistId String     @map("checklist_id")
  checklist   checklists @relation(fields: [checklistId], references: [id])
  title       String
  completed   Boolean    @default(false)
  createdAt   DateTime   @default(now()) @map("created_at")

  @@map("Checklist_Items")
}

model cardComments {
  id        String   @id @default(uuid())
  cardId    String   @map("card_id")
  card      cards    @relation(fields: [cardId], references: [id])
  userId    String   @map("user_id")
  user      users    @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("Card_Comments")
}

model cardAttachments {
  id        String   @id @default(uuid())
  cardId    String   @map("card_id")
  card      cards    @relation(fields: [cardId], references: [id])
  userId    String   @map("user_id")
  user      users    @relation(fields: [userId], references: [id])
  fileName  String   @map("file_name")
  fileUrl   String   @map("file_url")
  fileSize  Int      @map("file_size")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("Card_Attachments")
}

model cardActivity {
  id        String   @id @default(uuid())
  cardId    String   @map("card_id")
  card      cards    @relation(fields: [cardId], references: [id])
  userId    String   @map("user_id")
  user      users    @relation(fields: [userId], references: [id])
  action    String // "created", "updated", "moved", "labeled"
  details   String? // JSON details về thay đổi
  createdAt DateTime @default(now()) @map("created_at")

  @@map("Card_Activity")
}

model invitations {
  id         String               @id @default(uuid())
  projectId  String?              @map("project_id")
  boardId    String?              @map("board_id")
  email      String?
  roleId     String               @map("role_id")
  token      String               @unique
  type       InvitationTypeEnum   @default(EMAIL)
  status     InvitationStatusEnum @default(PENDING)
  createdBy  String               @map("created_by")
  owner      users                @relation(fields: [createdBy], references: [id])
  createdAt  DateTime             @default(now())
  expiresAt  DateTime             @map("expires_at")
  acceptedAt DateTime?            @map("accepted_at")
  project    projects?            @relation("ProjectInvitation", fields: [projectId], references: [id])
  board      boards?              @relation("BoardInvitation", fields: [boardId], references: [id])

  @@index([email, status])
  @@map("Invitations")
}



model Notifications {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        users    @relation(fields: [userId], references: [id])

  actorId     String?  @map("actor_id")
  type        NotificationTypeEnum
  title       String
  content     String
  entityType  NotificationEntityTypeEnum? @map("entity_type")
  entityId    String?  @map("entity_id")
  metadata    Json?
  isRead      Boolean  @default(false) @map("is_read")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
  @@map("Notifications")
}